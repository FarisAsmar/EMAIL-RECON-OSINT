@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&display=swap');

:root {
  --bg: #020408;
  --bg2: #080d14;
  --bg3: #0d1520;
  --bg4: #131e2c;
  --border: rgba(0,255,150,0.08);
  --border2: rgba(0,255,150,0.15);
  --text: #e8f0fe;
  --text2: #7a8fa6;
  --text3: #3d5068;
  --green: #00ff96;
  --green2: #00d4a0;
  --green-dim: rgba(0,255,150,0.07);
  --green-glow: 0 0 30px rgba(0,255,150,0.25);
  --blue: #4db8ff;
  --blue2: #0090ff;
  --blue-dim: rgba(77,184,255,0.07);
  --red: #ff4560;
  --red-dim: rgba(255,69,96,0.08);
  --amber: #ffb347;
  --amber-dim: rgba(255,179,71,0.08);
  --font: 'Syne', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --r: 12px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--font); min-height: 100vh; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
a { text-decoration: none; color: inherit; }
.app { min-height: 100vh; display: flex; flex-direction: column; position: relative; }
.bg-grid { position: fixed; inset: 0; z-index: 0; pointer-events: none; background-image: linear-gradient(rgba(0,255,150,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,150,0.025) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%); }
.bg-orb { position: fixed; border-radius: 50%; pointer-events: none; z-index: 0; filter: blur(120px); opacity: 0.12; }
.bg-orb-1 { width: 600px; height: 600px; background: var(--green); top: -200px; left: -200px; animation: orbFloat1 20s ease-in-out infinite; }
.bg-orb-2 { width: 500px; height: 500px; background: var(--blue); bottom: -200px; right: -100px; animation: orbFloat2 25s ease-in-out infinite; }
.bg-orb-3 { width: 300px; height: 300px; background: var(--green2); top: 50%; left: 50%; transform: translate(-50%,-50%); animation: orbFloat3 15s ease-in-out infinite; }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0)} 33%{transform:translate(80px,60px)} 66%{transform:translate(-40px,80px)} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0)} 33%{transform:translate(-60px,-80px)} 66%{transform:translate(40px,-40px)} }
@keyframes orbFloat3 { 0%,100%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,-50%) scale(1.3)} }
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(2,4,8,0.7); backdrop-filter: blur(24px) saturate(180%); border-bottom: 1px solid var(--border); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; height: 68px; display: flex; align-items: center; justify-content: space-between; }
.nav-logo { display: flex; align-items: center; gap: 12px; cursor: pointer; font-size: 18px; font-weight: 800; letter-spacing: -0.3px; color: var(--text); }
.nav-logo-mark { width: 36px; height: 36px; border-radius: 9px; position: relative; background: linear-gradient(135deg, var(--green), var(--blue)); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: #000; box-shadow: var(--green-glow); }
.nav-links { display: flex; align-items: center; gap: 2px; }
.nav-link { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text2); background: none; border: none; cursor: pointer; padding: 8px 16px; border-radius: 7px; transition: all 0.2s; position: relative; }
.nav-link:hover { color: var(--text); background: var(--green-dim); }
.nav-link.active { color: var(--green); }
.nav-link.active::after { content: ''; position: absolute; bottom: 4px; left: 50%; transform: translateX(-50%); width: 4px; height: 4px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); }
.nav-cta { font-family: var(--font-mono); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; background: transparent; border: 1px solid var(--border2); color: var(--green); border-radius: 8px; padding: 9px 20px; cursor: pointer; transition: all 0.2s; }
.nav-cta:hover { background: var(--green-dim); box-shadow: var(--green-glow); }
.main { flex: 1; position: relative; z-index: 1; padding-top: 68px; }
.page { max-width: 1200px; margin: 0 auto; padding: 80px 40px; }
.hero { min-height: calc(100vh - 68px); display: flex; flex-direction: column; justify-content: center; padding: 80px 40px; max-width: 1200px; margin: 0 auto; }
.hero-status { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); margin-bottom: 32px; }
.hero-status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 12px var(--green); animation: blink 2s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.hero-status-line { width: 32px; height: 1px; background: var(--green); opacity: 0.5; }
.hero-title { font-size: clamp(42px, 6.5vw, 82px); font-weight: 800; line-height: 1.0; letter-spacing: -2px; margin-bottom: 28px; color: var(--text); }
.hero-title .line2 { display: block; }
.hero-title .hl { background: linear-gradient(90deg, var(--green), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-desc { font-family: var(--font-mono); font-size: 15px; color: var(--text2); line-height: 1.8; max-width: 520px; margin-bottom: 48px; }
.hero-actions { display: flex; align-items: center; gap: 16px; margin-bottom: 72px; }
.btn-primary { display: inline-flex; align-items: center; gap: 10px; background: linear-gradient(135deg, var(--green), var(--green2)); color: #000; font-family: var(--font); font-size: 14px; font-weight: 800; letter-spacing: 0.02em; padding: 14px 32px; border-radius: 10px; border: none; cursor: pointer; transition: all 0.2s; }
.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 32px rgba(0,255,150,0.3); }
.btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--text2); font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 24px; border-radius: 10px; border: 1px solid var(--border); cursor: pointer; transition: all 0.2s; }
.btn-secondary:hover { color: var(--text); border-color: var(--border2); }
.hero-stats { display: flex; gap: 40px; padding-top: 40px; border-top: 1px solid var(--border); }
.stat { display: flex; flex-direction: column; gap: 4px; }
.stat-num { font-size: 28px; font-weight: 800; color: var(--text); line-height: 1; }
.stat-num span { background: linear-gradient(90deg, var(--green), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-label { font-family: var(--font-mono); font-size: 11px; color: var(--text3); letter-spacing: 0.08em; text-transform: uppercase; }
.scan-section { padding: 0 40px 80px; max-width: 1200px; margin: 0 auto; }
.scan-container { background: var(--bg2); border: 1px solid var(--border); border-radius: 16px; padding: 40px; position: relative; overflow: hidden; }
.scan-container::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--green), var(--blue), transparent); }
.scan-label { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
.scan-label::before { content: '//'; color: var(--green); }
.scan-form { display: flex; gap: 12px; }
.input-wrap { flex: 1; display: flex; align-items: center; gap: 12px; background: var(--bg3); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 0 20px; transition: border-color 0.2s, box-shadow 0.2s; }
.input-wrap:focus-within { border-color: var(--green); box-shadow: 0 0 0 3px rgba(0,255,150,0.08); }
.input-at { font-family: var(--font-mono); color: var(--green); font-size: 16px; font-weight: 600; }
.email-input { flex: 1; background: none; border: none; outline: none; font-family: var(--font-mono); font-size: 15px; color: var(--text); padding: 17px 0; letter-spacing: 0.02em; }
.email-input::placeholder { color: var(--text3); }
.btn-scan { background: linear-gradient(135deg, var(--green), var(--green2)); color: #000; border: none; border-radius: 10px; padding: 0 32px; font-family: var(--font); font-size: 14px; font-weight: 800; cursor: pointer; transition: all 0.2s; white-space: nowrap; display: flex; align-items: center; gap: 10px; min-height: 58px; }
.btn-scan:hover:not(:disabled) { box-shadow: 0 8px 24px rgba(0,255,150,0.3); transform: translateY(-1px); }
.btn-scan:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.scan-note { font-family: var(--font-mono); font-size: 11px; color: var(--text3); margin-top: 14px; }
.steps-section { padding: 0 40px 80px; max-width: 1200px; margin: 0 auto; }
.section-header { margin-bottom: 32px; }
.section-tag { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.section-tag::before { content: '//'; }
.section-title { font-size: 28px; font-weight: 800; color: var(--text); letter-spacing: -0.5px; }
.steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.step-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 28px; position: relative; transition: border-color 0.2s, transform 0.2s; overflow: hidden; }
.step-card:hover { border-color: var(--border2); transform: translateY(-2px); }
.step-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--green), var(--blue)); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
.step-card:hover::after { transform: scaleX(1); }
.step-num { font-family: var(--font-mono); font-size: 11px; font-weight: 600; color: var(--green); letter-spacing: 0.1em; margin-bottom: 16px; }
.step-icon { font-size: 24px; margin-bottom: 14px; }
.step-title { font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 10px; letter-spacing: -0.2px; }
.step-desc { font-family: var(--font-mono); font-size: 12px; color: var(--text2); line-height: 1.7; }
.scan-log { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 24px 28px; margin: 0 auto 40px; max-width: calc(1200px - 80px); }
.log-header { font-family: var(--font-mono); font-size: 11px; color: var(--text3); letter-spacing: 0.08em; margin-bottom: 16px; }
.log-line { font-family: var(--font-mono); font-size: 13px; color: var(--text2); opacity: 0; animation: fadeIn 0.4s ease forwards; margin-bottom: 8px; }
.log-line:last-child { margin-bottom: 0; }
.log-delay-1 { animation-delay: 0.7s; } .log-delay-2 { animation-delay: 1.5s; } .log-delay-3 { animation-delay: 2.4s; }
@keyframes fadeIn { to { opacity: 1; } }
.log-ok { color: var(--green); margin-right: 10px; } .log-wait { color: var(--blue); margin-right: 10px; }
.error-box { background: var(--red-dim); border: 1px solid rgba(255,69,96,0.2); border-radius: 8px; padding: 14px 18px; font-family: var(--font-mono); font-size: 13px; color: var(--red); margin-top: 14px; }
.spinner { width: 14px; height: 14px; border: 2px solid rgba(0,0,0,0.2); border-top-color: #000; border-radius: 50%; animation: spin 0.6s linear infinite; display: inline-block; }
@keyframes spin { to { transform: rotate(360deg); } }
.results-page { padding: 40px; max-width: 1200px; margin: 0 auto; animation: slideUp 0.4s ease; }
@keyframes slideUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:none} }
.results-topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 36px; padding-bottom: 28px; border-bottom: 1px solid var(--border); }
.results-email-label { font-family: var(--font-mono); font-size: 11px; color: var(--text3); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
.results-email { font-size: 22px; font-weight: 800; color: var(--text); letter-spacing: -0.3px; }
.btn-back { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; background: var(--bg3); border: 1px solid var(--border); color: var(--text2); border-radius: 8px; padding: 10px 20px; cursor: pointer; transition: all 0.15s; }
.btn-back:hover { color: var(--text); border-color: var(--border2); }
.risk-card { border-radius: 16px; padding: 36px; margin-bottom: 16px; border: 1px solid; display: grid; grid-template-columns: 140px 1fr; gap: 36px; align-items: center; position: relative; overflow: hidden; }
.risk-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; }
.risk-card.critical { background: var(--red-dim); border-color: rgba(255,69,96,0.2); }
.risk-card.critical::before { background: linear-gradient(90deg, transparent, var(--red), transparent); }
.risk-card.warn { background: var(--amber-dim); border-color: rgba(255,179,71,0.2); }
.risk-card.warn::before { background: linear-gradient(90deg, transparent, var(--amber), transparent); }
.risk-card.safe { background: var(--green-dim); border-color: rgba(0,255,150,0.15); }
.risk-card.safe::before { background: linear-gradient(90deg, transparent, var(--green), transparent); }
.risk-card.neutral { background: var(--bg2); border-color: var(--border); }
.risk-score { font-size: 64px; font-weight: 800; line-height: 1; letter-spacing: -2px; }
.risk-card.critical .risk-score { color: var(--red); } .risk-card.warn .risk-score { color: var(--amber); } .risk-card.safe .risk-score { color: var(--green); } .risk-card.neutral .risk-score { color: var(--text3); }
.risk-score-sub { font-family: var(--font-mono); font-size: 11px; color: var(--text3); margin-top: 4px; letter-spacing: 0.06em; }
.risk-label { font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
.risk-card.critical .risk-label { color: var(--red); } .risk-card.warn .risk-label { color: var(--amber); } .risk-card.safe .risk-label { color: var(--green); }
.risk-summary { font-size: 16px; color: var(--text); line-height: 1.7; }
.chain-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 16px; padding: 32px; margin-bottom: 16px; position: relative; overflow: hidden; }
.chain-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(0,255,150,0.3), transparent); }
.chain-header { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
.chain-title { font-size: 16px; font-weight: 800; color: var(--text); letter-spacing: -0.2px; }
.chain-badge { font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; padding: 4px 12px; border-radius: 20px; }
.chain-badge.viable { background: var(--red-dim); color: var(--red); border: 1px solid rgba(255,69,96,0.2); }
.chain-badge.blocked { background: var(--green-dim); color: var(--green); border: 1px solid rgba(0,255,150,0.15); }
.chain-flow { display: flex; align-items: center; overflow-x: auto; padding: 8px 0; }
.chain-node { display: flex; flex-direction: column; align-items: center; gap: 8px; min-width: 96px; }
.chain-icon { width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 13px; font-weight: 700; border: 1px solid; }
.chain-icon.red { background: var(--red-dim); border-color: rgba(255,69,96,0.3); color: var(--red); }
.chain-icon.green { background: var(--green-dim); border-color: rgba(0,255,150,0.2); color: var(--green); }
.chain-icon.amber { background: var(--amber-dim); border-color: rgba(255,179,71,0.3); color: var(--amber); }
.chain-icon.muted { background: var(--bg3); border-color: rgba(255,255,255,0.06); color: var(--text3); }
.chain-node-name { font-size: 13px; font-weight: 700; color: var(--text); }
.chain-node-sub { font-family: var(--font-mono); font-size: 10px; color: var(--text3); text-align: center; letter-spacing: 0.04em; }
.chain-arrow { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 44px; padding-bottom: 40px; }
.chain-arrow-label { font-family: var(--font-mono); font-size: 9px; color: var(--text3); letter-spacing: 0.06em; text-transform: uppercase; }
.chain-arrow-row { display: flex; align-items: center; width: 100%; }
.chain-arrow-line { flex: 1; height: 1px; }
.chain-arrow.on .chain-arrow-line { background: linear-gradient(90deg, var(--green), var(--red)); }
.chain-arrow.off .chain-arrow-line { background: rgba(255,255,255,0.06); }
.chain-arrow-tip { font-size: 18px; margin-left: -4px; }
.chain-arrow.on .chain-arrow-tip { color: var(--red); } .chain-arrow.off .chain-arrow-tip { color: rgba(255,255,255,0.1); }
.chain-explain { background: rgba(255,69,96,0.05); border: 1px solid rgba(255,69,96,0.15); border-radius: 10px; padding: 18px 20px; font-size: 14px; color: var(--text); line-height: 1.75; margin-top: 20px; display: flex; gap: 12px; }
.chain-explain-icon { color: var(--red); flex-shrink: 0; font-size: 16px; }
.chain-explain strong { color: var(--green); font-weight: 600; }
.platforms-label { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; }
.platforms-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
.platform-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 22px; position: relative; overflow: hidden; }
.platform-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; }
.platform-card.red::before { background: var(--red); } .platform-card.amber::before { background: var(--amber); } .platform-card.green::before { background: var(--green); } .platform-card.muted::before { background: var(--text3); }
.platform-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.platform-logo { width: 36px; height: 36px; border-radius: 9px; background: var(--bg3); border: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; font-weight: 700; color: var(--text3); }
.platform-name { font-size: 15px; font-weight: 700; color: var(--text); flex: 1; }
.risk-pill { font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: 0.05em; padding: 3px 10px; border-radius: 20px; }
.risk-pill.red { background: var(--red-dim); color: var(--red); } .risk-pill.amber { background: var(--amber-dim); color: var(--amber); } .risk-pill.green { background: var(--green-dim); color: var(--green); } .risk-pill.muted { background: var(--bg3); color: var(--text3); }
.platform-status { font-family: var(--font-mono); font-size: 11px; color: var(--text3); margin-bottom: 8px; }
.platform-status span { color: var(--text2); }
.platform-detail { font-family: var(--font-mono); font-size: 12px; color: var(--text2); line-height: 1.65; }
.mitigation-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 16px; padding: 32px; position: relative; overflow: hidden; }
.mitigation-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(77,184,255,0.4), transparent); }
.mitigation-title { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 24px; letter-spacing: -0.2px; }
.mitigations { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.mit-num { font-family: var(--font-mono); font-size: 11px; font-weight: 600; color: var(--blue); letter-spacing: 0.08em; margin-bottom: 10px; }
.mit-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.mit-body { font-family: var(--font-mono); font-size: 12px; color: var(--text2); line-height: 1.7; }
.about-page { max-width: 900px; }
.about-hero { margin-bottom: 56px; }
.about-tag { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
.about-tag::before { content: '//'; }
.about-title { font-size: clamp(32px, 5vw, 52px); font-weight: 800; letter-spacing: -1px; color: var(--text); margin-bottom: 20px; line-height: 1.1; }
.about-title .hl { background: linear-gradient(90deg, var(--green), var(--blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.about-subtitle { font-family: var(--font-mono); font-size: 15px; color: var(--text2); line-height: 1.8; max-width: 640px; }
.about-grid { display: flex; flex-direction: column; gap: 12px; }
.about-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 16px; padding: 32px; position: relative; overflow: hidden; transition: border-color 0.2s; }
.about-card:hover { border-color: var(--border2); }
.about-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(0,255,150,0.2), transparent); }
.about-card-label { font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); margin-bottom: 16px; }
.about-text { font-family: var(--font-mono); font-size: 14px; color: var(--text2); line-height: 1.85; }
.about-text p { margin-bottom: 16px; } .about-text p:last-child { margin-bottom: 0; }
.about-text strong { color: var(--text); font-weight: 600; }
.author-row { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
.author-avatar { width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, var(--green), var(--blue)); display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: #000; box-shadow: 0 0 20px rgba(0,255,150,0.3); flex-shrink: 0; }
.author-name { font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 4px; }
.author-role { font-family: var(--font-mono); font-size: 12px; color: var(--text3); }
.stack-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
.stack-tag { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 6px 14px; font-family: var(--font-mono); font-size: 11px; font-weight: 500; color: var(--text2); transition: all 0.15s; }
.stack-tag:hover { border-color: var(--green); color: var(--green); }
.footer { position: relative; z-index: 1; border-top: 1px solid var(--border); padding: 28px 40px; }
.footer-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
.footer-left { font-family: var(--font-mono); font-size: 12px; color: var(--text3); }
.footer-right { display: flex; gap: 24px; }
.footer-link { font-family: var(--font-mono); font-size: 12px; color: var(--text3); transition: color 0.15s; }
.footer-link:hover { color: var(--green); }
@media (max-width: 768px) {
  .nav-inner { padding: 0 20px; }
  .hero { padding: 60px 20px; }
  .hero-stats { gap: 24px; flex-wrap: wrap; }
  .page, .scan-section, .steps-section { padding-left: 20px; padding-right: 20px; }
  .scan-form { flex-direction: column; }
  .btn-scan { min-height: 52px; justify-content: center; }
  .steps, .platforms-grid, .mitigations { grid-template-columns: 1fr; }
  .risk-card { grid-template-columns: 1fr; gap: 20px; }
  .results-page { padding: 20px; }
  .footer { padding: 20px; }
  .scan-log { margin: 0 20px 32px; }
}
